# Central version configuration for kind-cilium-fluxcd project
# Update versions here — they are sourced by all scripts.
# ----------------------------------------------------------

# KinD node image
KIND_NODE_VERSION="v1.35.0"
KIND_NODE_DIGEST="sha256:452d707d4862f52530247495d180205e029056831160e22870e37e3f6c1ac31f"
KIND_NODE_IMAGE="kind-node-extra-ca"

# FluxCD controller versions
HELM_CONTROLLER_VERSION="v1.3.0"
KUSTOMIZE_CONTROLLER_VERSION="v1.6.1"
NOTIFICATION_CONTROLLER_VERSION="v1.6.0"
SOURCE_CONTROLLER_VERSION="v1.6.2"

# Podinfo application
PODINFO_VERSION="6.10.1"

# Docker registry proxy
DOCKER_REGISTRY_PROXY_VERSION="0.6.2"

# Cilium CNI
CILIUM_HELM_CHART_VERSION="1.19.0"
CILIUM_AGENT_TAG="v1.19.0"
CILIUM_OPERATOR_TAG="v1.19.0"
CILIUM_ENVOY_TAG="v1.35.9-1768828720-c6e4827ebca9c47af2a3a6540c563c30947bae29"
HUBBLE_RELAY_TAG="v1.19.0"
HUBBLE_UI_BE_TAG="v0.13.3"
HUBBLE_UI_FE_TAG="v0.13.3"

# Gateway API CRDs
GATEWAY_API_VERSION="v1.3.0"

# Local Docker registry
REGISTRY="localhost:5001"
REGISTRY_NAME="kind-registry"
REGISTRY_PORT="5001"

# kube-prometheus-stack
KUBE_PROMETHEUS_STACK_VERSION="82.15.1"

# Grafana Loki + Alloy (log aggregation)
LOKI_HELM_CHART_VERSION="6.55.0"
ALLOY_HELM_CHART_VERSION="1.6.2"

# SeaweedFS (S3-compatible object storage)
SEAWEEDFS_HELM_CHART_VERSION="4.17.0"

# OpenBao (secret management)
OPENBAO_HELM_CHART_VERSION="0.26.2"

# CloudNativePG (PostgreSQL operator)
CNPG_HELM_CHART_VERSION="0.27.1"

# Valkey (key-value cache, open-source Redis replacement)
VALKEY_HELM_CHART_VERSION="5.4.3"

# MongoDB (NoSQL document database)
MONGODB_HELM_CHART_VERSION="18.6.20"

# Zabbix (monitoring and alerting platform)
ZABBIX_HELM_CHART_VERSION="7.0.12"

# Example app container images (pinned to avoid floating tags)
NGINX_ALPINE_VERSION="1.27-alpine"
AWS_CLI_VERSION="2.27.2"
BUSYBOX_VERSION="1.37"
POSTGRES_VERSION="18"
BITNAMI_VALKEY_VERSION="8.1.3"
BITNAMI_MONGODB_VERSION="8.0.10"

# Optional extra CA certificate to inject into images (e.g. for a corporate
# MITM proxy such as Zscaler, Netskope, Palo Alto, etc.).
# Leave EXTRA_CA_CERT empty to build images without injecting a custom CA.
# Example: EXTRA_CA_CERT=/usr/local/share/ca-certificates/ZscalerRootCertificate-2048-SHA256.crt
EXTRA_CA_CERT="${EXTRA_CA_CERT:-}"
EXTRA_CA_CERT_FILENAME="extra-ca.crt"
